{
  "name": "fe-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "precommit": "bun run lint && bun run typecheck",
    "preinstall": "node 'scripts/enforce-bun.js' && npx only-allow bun",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "dev": "next dev",
    "build": "bun run lint && bun run tsc && next build",
    "start": "next start"
  },
  "dependencies": {
    "@szhsin/react-accordion": "^1.4.2",
    "@tanstack/react-query": "^5.101.0",
    "clsx": "^2.1.1",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.6.0",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "packageManager": "bun@1.1.3",
  "engines": {
    "npm": "please-use-bun",
    "yarn": "please-use-bun",
    "bun": ">= 1.1.0"
  }
}
