{
  "name": "take-home",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "app.ts",
  "scripts": {
    "format": "prettier --write 'src/**/*.ts' 'scripts/**/*.{js,ts}'",
    "precommit": "bun run lint && bun run typecheck && bun run build",
    "preinstall": "npx only-allow bun",
    "prepare": "bun run husky install",
    "dev": "bun --watch src/app.ts",
    "start": "node dist/app.js",
    "lint": "eslint 'src/**/*.ts' 'scripts/**/*.{js,ts}'",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.9",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.1.3",
  "engines": {
    "yarn": "please-use-bun",
    "npm": "please-use-bun",
    "bun": ">= 1.1.0"
  }
}
